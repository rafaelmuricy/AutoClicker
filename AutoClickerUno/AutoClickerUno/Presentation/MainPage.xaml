<Page x:Class="AutoClickerUno.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:AutoClickerUno.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      NavigationCacheMode="Required"
      x:Name="Root"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
    </Page.Resources>
    
    <ScrollViewer IsTabStop="True">
        <Grid utu:SafeArea.Insets="VisibleBounds"  Name="MainGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"  />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Button Content="{Binding BtCaptureLabel}" Command="{Binding Capture}" Grid.Row="0" HorizontalAlignment="Stretch" ></Button>
            <TextBlock Text="Clicks:" Grid.Row="1" FontSize="18" Margin="5" />
            <ScrollViewer Grid.Row="2" >
                <StackPanel Spacing="16" VerticalAlignment="Top" Margin="5" >
                    <ItemsControl ItemsSource="{Binding clicks}" >
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontSize="12">
                                        <Run Text="Title" />
                                        <Run Text="{Binding WindowTitle}" />
                                        <LineBreak />
                                        <Run Text="Process" />
                                        <Run Text="{Binding Process}" />
                                        <LineBreak />
                                        <Run Text="PID" />
                                        <Run Text="{Binding Pid}" />
                                        <LineBreak />
                                        <Run Text="X: " />
                                        <Run Text="{Binding Point.X}" />
                                        <Run Text="Y: " />
                                        <Run Text="{Binding Point.Y}" />
                                    </TextBlock>
                                    <TextBlock FontSize="12">
                                    <Run Text="Delay: " />
                                    <Run Text="{Binding Delay}" />
                                    </TextBlock>
                                    <TextBlock FontSize="12">
                                    <Run Text="Time Left: " />
                                    <Run Text="{Binding TimeLeft}" />
                                    </TextBlock>


                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="-" HorizontalAlignment="Stretch" Grid.Column="0"  Command="{utu:ItemsControlBinding Path=DataContext.Minus}" CommandParameter="{Binding}" />
                                        <Button Content="+" HorizontalAlignment="Stretch" Grid.Column="1" Command="{utu:ItemsControlBinding Path=DataContext.Plus}" CommandParameter="{Binding}" />
                                    </Grid>
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="{Binding BtStartStopLabel}" Grid.Column="0" HorizontalAlignment="Stretch" Command="{utu:ItemsControlBinding Path=DataContext.StartStop}" CommandParameter="{Binding}" />
                                        <Button Content="X" Grid.Column="1" HorizontalAlignment="Stretch" Command="{utu:ItemsControlBinding Path=DataContext.Delete}" CommandParameter="{Binding}"></Button>
                                    </Grid>

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
            <TextBlock Text="{Binding Clock}" Grid.Row="3" FontSize="18" />
            <Button Content="{Binding BtStartStopLabel}" Command="{Binding StartStopAll}" Grid.Row="4" HorizontalAlignment="Stretch"></Button>
        </Grid>
    </ScrollViewer>
</Page>
